[
  {
    "match": { "anyFlagPrefix": ["-i", "-I", "--in-place"] },
    "type": "filesystem_write",
    "_comment": "sed -i, -I, -i.bak, --in-place, --in-place=.bak"
  },
  {
    "match": { "tokenMatches": "^-[^-]*[iI]" },
    "type": "filesystem_write",
    "_comment": "combined short flags: -ni, -nI, -ein, etc."
  }
]
