  "sed": [
    {
      "match": {
        "anyFlagPrefix": [
          "-i",
          "-I",
          "--in-place"
        ]
      },
      "type": "filesystem_write"
    },
    {
      "match": {
        "tokenMatches": "^-[^-]*[iI]"
      },
      "type": "filesystem_write"
    }
  ]
