{
  "awk": [
    {
      "match": {
        "anyToken": "system("
      },
      "type": "lang_exec"
    },
    {
      "match": {
        "anyToken": "| getline"
      },
      "type": "lang_exec"
    },
    {
      "match": {
        "anyToken": "|&"
      },
      "type": "lang_exec"
    },
    {
      "match": {
        "anyToken": "| \""
      },
      "type": "lang_exec"
    },
    {
      "match": {
        "anyToken": "print >"
      },
      "type": "lang_exec"
    }
  ],
  "bun": [
    {
      "match": {
        "anyFlag": [
          "-g",
          "--global",
          "--system",
          "--target",
          "--root"
        ]
      },
      "type": "unknown"
    }
  ],
  "cargo": [
    {
      "match": {
        "anyFlag": [
          "-g",
          "--global",
          "--system",
          "--target",
          "--root"
        ]
      },
      "type": "unknown"
    }
  ],
  "crontab": [
    {
      "match": {
        "anyFlag": [
          "-l"
        ]
      },
      "type": "filesystem_read"
    }
  ],
